    "NSMicrophoneUsageDescription": {
      "comment": "Privacy - Microphone Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "OpenTypeless needs microphone access to transcribe your voice."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenTypeless necesita acceso al micrófono para transcribir tu voz."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenTypelessは音声を文字起こしするためにマイクへのアクセスが必要です。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenTypeless precisa de acesso ao microfone para transcrever sua voz."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenTypeless necessita dell'accesso al microfono per trascrivere la tua voce."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenTypeless heeft toegang tot de microfoon nodig om je stem te kunnen transcriberen."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenTypeless이 귀하의 음성을 텍스트로 변환하려면 마이크 액세스 권한이 필요합니다."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenTypeless'un sesinizi yazıya dökebilmesi için mikrofona erişmesi gerekiyor."
          }
        }
      }
    }
  },
  "version": "1.1"
